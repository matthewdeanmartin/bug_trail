<!DOCTYPE html>
<html lang="en">
<head>
    {% block head %}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
    <style>
        .log-detail { font-family: Arial, sans-serif; margin: 20px; }
        .log-detail dt { font-weight: bold; }
        .log-detail dd { margin: 0 0 20px 0; padding: 0 0 0 20px; }
        .bt-brand img { height: 28px; margin-right: 8px; vertical-align: middle; }
        pre { background: #f7f7f9; padding: 12px; border-radius: 4px; overflow-x: auto; }
        .danger-zone { border: 1px solid #dc3545; padding: 16px; border-radius: 6px; }
    </style>
    <title>{% block title %}Bug Trail{% endblock %}</title>
    {% endblock %}
</head>
<body>
    {% include "view_navbar.jinja" %}
    <main id="content" class="container-fluid py-3">{% block content %}{% endblock %}</main>
    <footer class="container-fluid py-3 text-muted small">
        {% block footer %}
        &copy; Copyright 2024 Matthew Martin &mdash; MIT License. Bug Trail live server.
        {% endblock %}
    </footer>
    <script>
      (function () {
        if (typeof EventSource === "undefined") return;
        let debounce = null;
        const es = new EventSource("/events");
        es.onmessage = function (e) {
          if (e.data !== "refresh") return;
          if (debounce) clearTimeout(debounce);
          debounce = setTimeout(function () { location.reload(); }, 500);
        };
        es.onerror = function () { /* browser auto-retries */ };
      })();
    </script>
</body>
</html>
