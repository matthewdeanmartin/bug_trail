{% extends "view_base.jinja" %}
{% block title %}Bug Trail &mdash; Python Environment{% endblock %}
{% block content %}
<h1 class="h3 mb-3">Python Environment</h1>
{% if not logs %}
  <p class="text-muted">No library info recorded.</p>
{% else %}
<div class="table-responsive">
<table class="table table-striped table-sm">
  <thead>
    <tr>
      <th>Library</th>
      <th>Version</th>
      <th>URLs</th>
    </tr>
  </thead>
  <tbody>
    {% for log in logs %}
    <tr>
      <td>{{ log.library_name }}</td>
      <td>{{ log.version }}</td>
      <td>
        {% for name, url in log.urls.items() %}
          <a href="{{ url }}" target="_blank" rel="noopener">{{ name }}</a><br>
        {% endfor %}
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
</div>
{% endif %}
{% endblock %}
